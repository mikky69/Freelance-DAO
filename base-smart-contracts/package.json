{
  "name": "freelance-dao",
  "version": "2.0.0",
  "description": "FreeLanceDAO smart contracts — Base blockchain (migrated from Hedera)",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "hardhat test test/unit/*.test.ts",
    "test:integration": "hardhat test test/integration/*.test.ts",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat deploy --network localhost",
    "deploy:base-sepolia": "hardhat deploy --network baseSepolia",
    "node": "hardhat node",
    "clean": "hardhat clean",
    "verify:base-sepolia": "hardhat run scripts/verify.ts --network baseSepolia",
    "slither": "bash scripts/slither.sh",
    "mythril": "bash scripts/mythril.sh",
    "lint:sol": "solhint \"contracts/**/*.sol\"",
    "lint:ts": "eslint \"test/**/*.ts\" \"deploy/**/*.ts\" \"scripts/**/*.ts\" --ext .ts",
    "lint:ts:fix": "eslint \"test/**/*.ts\" \"deploy/**/*.ts\" \"scripts/**/*.ts\" --ext .ts --fix",
    "format": "prettier --write \"contracts/**/*.sol\" \"test/**/*.ts\" \"deploy/**/*.ts\""
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.7",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/ignition-core": "^0.15.7",
    "@openzeppelin/contracts": "5.0.2",
    "@openzeppelin/contracts-upgradeable": "5.0.2",
    "@openzeppelin/hardhat-upgrades": "^3.2.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.12.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "ethers": "^6.4.0",
    "hardhat": "^2.22.0",
    "hardhat-deploy": "^0.12.4",
    "hardhat-gas-reporter": "^1.0.8",
    "prettier": "^3.2.5",
    "prettier-plugin-solidity": "^1.3.1",
    "solidity-coverage": "^0.8.12",
    "solhint": "^5.0.1",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.0",
    "typescript": "^5.4.5"
  }
}