# ============================================================
# FreeLanceDAO — Environment Variables
# ============================================================

# Deployer private key (no 0x prefix needed in some setups, add it here)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Base Sepolia RPC (get a free one from Alchemy or Infura)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# BaseScan API key for contract verification
# Get from: https://basescan.org/apis
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# DAO Treasury address (the wallet that receives all fees/penalties)
DAO_TREASURY_ADDRESS=0xYOUR_DAO_TREASURY_ADDRESS

# CoinMarketCap API key (optional, for gas reporter in USD)
COINMARKETCAP_API_KEY=YOUR_CMC_KEY

# Set to "true" to generate gas report on test runs
REPORT_GAS=true

# ============================================================
# Chainlink Price Feed Addresses
# ============================================================
# Base Sepolia ETH/USD feed
ETH_USD_FEED_BASE_SEPOLIA=0x4aDC67696bA383F43DD60A9e78F2C97Fbbfc7cb
